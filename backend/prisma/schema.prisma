// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "mysql"
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum CandidateStatus {
  pending
  reviewed
  interviewing
  completed
}

enum Confidence {
  high
  medium
  low
}

enum InterviewStatus {
  scheduled
  completed
  cancelled
}

enum Difficulty {
  easy
  medium
  hard
}

enum WorkspaceRole {
  super_admin
  admin
  reviewer
}

enum InvitationStatus {
  pending
  accepted
  expired
  cancelled
}

enum ResumeFileStatus {
  uploaded
  parsing
  parsed
  failed
}

// ─── Models ───────────────────────────────────────────────────────────────────

model Workspace {
  id          Int               @id @default(autoincrement())
  name        String            @db.VarChar(200)
  slug        String            @unique @db.VarChar(100)
  ownerId     Int
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  owner             User               @relation("WorkspaceOwner", fields: [ownerId], references: [id], onDelete: Restrict)
  members           WorkspaceMember[]
  invitations       Invitation[]
  candidates        Candidate[]

  @@map("workspaces")
}

model WorkspaceMember {
  id          Int           @id @default(autoincrement())
  role        WorkspaceRole @default(reviewer)
  joinedAt    DateTime      @default(now())
  userId      Int
  workspaceId Int

  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace   Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([userId, workspaceId])
  @@map("workspace_members")
}

model Invitation {
  id          Int              @id @default(autoincrement())
  email       String           @db.VarChar(150)
  role        WorkspaceRole    @default(admin)
  token       String           @unique @db.VarChar(255)
  status      InvitationStatus @default(pending)
  expiresAt   DateTime
  workspaceId Int
  invitedById Int
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  workspace   Workspace        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  invitedBy   User             @relation(fields: [invitedById], references: [id])

  @@unique([workspaceId, email])
  @@map("invitations")
}

model User {
  id                Int               @id @default(autoincrement())
  name              String            @db.VarChar(100)
  organizationName  String            @db.VarChar(200)
  email             String            @unique @db.VarChar(150)
  passwordHash      String            @db.VarChar(255)
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  ownedWorkspaces   Workspace[]       @relation("WorkspaceOwner")
  workspaces        WorkspaceMember[]
  invitationsSent   Invitation[]
  interviewSessions InterviewSession[]

  @@map("users")
}

model Candidate {
  id               Int               @id @default(autoincrement())
  name             String            @db.VarChar(100)
  email            String            @db.VarChar(150)
  resume           String?           @db.VarChar(500)
  resumeKey        String?           @db.VarChar(300)
  board            String            @db.VarChar(50)
  grade10          String            @db.Text
  grade12          String            @db.Text
  gpa              String            @db.Text
  degree           String            @db.VarChar(150)
  status           CandidateStatus   @default(pending)
  summary          String?           @db.Text
  aiSummary        String?           @db.Text
  activities       Json              // string[]
  achievements     Json              // string[]
  strengths        Json              // string[]
  growthAreas      Json              // string[]
  skills           Json              // string[]
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  workspaceId      Int

  workspace          Workspace           @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  essays             Essay[]
  parsedFields       ParsedField[]
  academicRecords    AcademicRecord[]
  competitiveExams   CompetitiveExam[]
  interviewQuestions InterviewQuestion[]
  interviewSessions  InterviewSession[]
  resumeFiles        ResumeFile[]

  @@map("candidates")
}

model ResumeFile {
  id           Int       @id @default(autoincrement())
  originalName String    @db.VarChar(255)
  mimeType     String    @db.VarChar(100)
  size         Int
  resumeUrl    String    @db.VarChar(500)
  resumeKey    String    @db.VarChar(300)
  status       ResumeFileStatus @default(uploaded)
  candidateId  Int?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  candidate    Candidate? @relation(fields: [candidateId], references: [id], onDelete: Cascade)

  @@index([candidateId])
  @@map("resume_files")
}

model Essay {
  id          Int       @id @default(autoincrement())
  title       String    @db.VarChar(200)
  content     String    @db.Text
  candidateId Int
  createdAt   DateTime  @default(now())

  candidate   Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)

  @@map("essays")
}

model ParsedField {
  id          Int        @id @default(autoincrement())
  field       String     @db.VarChar(100)
  value       String     @db.Text
  confidence  Confidence
  source      String     @db.VarChar(200)
  payload     Json?
  candidateId Int
  createdAt   DateTime   @default(now())

  candidate   Candidate  @relation(fields: [candidateId], references: [id], onDelete: Cascade)

  @@map("parsed_fields")
}

model AcademicRecord {
  id                    Int                @id @default(autoincrement())
  standard              String             @db.VarChar(50)
  schoolName            String             @db.VarChar(255)
  board                 String             @db.VarChar(100)
  yearOfPassing         String             @db.VarChar(20)
  markingScheme         String             @db.VarChar(100)
  obtainedPercentageOrCgpa String           @db.VarChar(50)
  candidateId           Int
  createdAt             DateTime           @default(now())

  candidate             Candidate          @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  subjects              AcademicSubject[]

  @@index([candidateId])
  @@map("academic_records")
}

model AcademicSubject {
  id                   Int            @id @default(autoincrement())
  subject              String         @db.VarChar(100)
  maximumMarksOrGrade  String         @db.VarChar(50)
  obtainedMarksOrGrade String         @db.VarChar(50)
  academicRecordId     Int
  createdAt            DateTime       @default(now())

  academicRecord       AcademicRecord @relation(fields: [academicRecordId], references: [id], onDelete: Cascade)

  @@index([academicRecordId])
  @@map("academic_subjects")
}

model CompetitiveExam {
  id               Int           @id @default(autoincrement())
  examName         String        @db.VarChar(100)
  status           String?       @db.VarChar(50)
  testDate         String?       @db.VarChar(20)
  rollNumber       String?       @db.VarChar(100)
  totalScore       String?       @db.VarChar(50)
  rankOrPercentile String?       @db.VarChar(50)
  result           String?       @db.VarChar(50)
  candidateId      Int
  createdAt        DateTime      @default(now())

  candidate        Candidate     @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  sectionScores    ExamSection[]

  @@index([candidateId])
  @@map("competitive_exams")
}

model ExamSection {
  id              Int            @id @default(autoincrement())
  section         String         @db.VarChar(100)
  score           String         @db.VarChar(50)
  competitiveExamId Int
  createdAt       DateTime       @default(now())

  competitiveExam CompetitiveExam @relation(fields: [competitiveExamId], references: [id], onDelete: Cascade)

  @@index([competitiveExamId])
  @@map("exam_sections")
}

model InterviewQuestion {
  id             String     @id @db.VarChar(20)
  category       String     @db.VarChar(50)
  difficulty     Difficulty
  question       String     @db.Text
  skillEvaluated String     @db.VarChar(200)
  rationale      String     @db.Text
  sourceText     String?    @db.Text
  confidence     Int?
  tags           Json       // string[]
  candidateId    Int?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  candidate      Candidate? @relation(fields: [candidateId], references: [id], onDelete: SetNull)

  @@map("interview_questions")
}

model InterviewSession {
  id            String          @id @db.VarChar(20)
  version       String          @db.VarChar(100)
  dateGenerated DateTime        @default(now())
  questionCount Int
  status        InterviewStatus @default(scheduled)
  candidateId   Int
  generatedById Int

  candidate     Candidate       @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  generatedBy   User            @relation(fields: [generatedById], references: [id])

  @@map("interview_sessions")
}
